# --- Database (matches docker-compose.yml defaults) ---
DATABASE_URL=postgresql+psycopg://raoc:raoc@localhost:5432/raoc

# --- Data source: Arctic Shift archive API (no API key required) ---
ARCTIC_SHIFT_BASE_URL=https://arctic-shift.photon-reddit.com
SUBREDDIT=RandomActsofCards
REQUEST_TAG=[Request]

# --- Google Gemini ---
# Create a key at https://aistudio.google.com/api-keys
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# --- Embeddings (local model) ---
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024

# --- RAG ---
RETRIEVAL_TOP_N=20

# --- API CORS (frontend dev servers) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
